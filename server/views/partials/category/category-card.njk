<a class="hmpps-category-card" href="{{ cardItem.href or '#' }}">
  {% if cardItem.thumbnailUrl %}
    <img class="hmpps-category__thumbnail" src="{{cardItem.thumbnailUrl}}" alt="" loading="lazy">
  {% endif %}
  <div class="hmpps-category-card__title">
    <h3 class="govuk-heading-s">{{ cardItem.title or cardItem.linkText or 'Untitled' }}</h3>
    {% if showContentTag and cardItem.contentType and cardItem.contentType != "series" and cardItem.contentType != "category" and cardItem.contentType != "category_bottom" and cardItem.contentType != "link" %}
      {% if cardItem.contentType == "video" %}
        <span class="hmpps-category-card__content-label hmpps-category-card__content-label--watch">{{ t("features:contentTile.watch") }}</span>
      {% elif cardItem.contentType == "radio" %}
        <span class="hmpps-category-card__content-label hmpps-category-card__content-label--listen">{{ t("features:contentTile.listen") }}</span>
      {% else %}
        <span class="hmpps-category-card__content-label hmpps-category-card__content-label--read">{{ t("features:contentTile.read") }}</span>
      {% endif %}
    {% endif %}
    {% if showSeriesTag and cardItem.contentType == "series" %}
      <strong class="govuk-tag govuk-tag--purple hmpps-category-card__tag">{{ t("features:contentTile.series") }}</strong>
    {% endif %}
  </div>
</a>
