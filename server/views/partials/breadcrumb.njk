{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% macro breadcrumbNavigation(t, showHomeLink=false) %}
<div class="page-navigation govuk-!-display-none-print">
  <nav class="page-navigation__links" aria-label="Page navigation">
    {% if showHomeLink %}
      <a href="/" class="page-navigation__link" ata-page-nav-action="home">{{ t("common:pageNavigation.home") }}</a>
    {% endif %}
    <a href="#" class="govuk-link page-navigation__link page-navigation__link--back" data-page-nav-action="back">{{ t("common:pageNavigation.back") }}</a>
    <a href="#" class="govuk-link page-navigation__link page-navigation__link--forward" data-page-nav-action="forward">{{ t("common:pageNavigation.forward") }}</a>
  </nav>
</div>

<hr class="govuk-width-container govuk-section-break govuk-section-break--visible">
{% endmacro %}

{% macro breadcrumb(breadcrumbs) %}

{{ govukBreadcrumbs({
  collapseOnMobile: true,
  items: breadcrumbs,
  classes: "govuk-!-display-none-print govuk-link govuk-link--no-visited-state hmpps-breadcrumbs"
}) }}

{% endmacro %}
