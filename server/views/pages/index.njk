{% from "../partials/category/category-block.njk" import categoryBlock %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% extends "../partials/layout.njk" %}

{% set pageTitle = applicationName + " - Home" %}
{% set mainClasses = "govuk-body" %}
{% set excludeFeedback = true %}

{% block content %}
  {{ govukButton({
    text: t("pages:home.browseAllTopics"),
    href: "/topics",
    isStartButton: true,
    classes: "govuk-!-margin-top-2 govuk-!-margin-bottom-2 govuk-!-margin-right-2"
  }) }}
  <section class="hmpps-section--dark govuk-!-padding-top-6 govuk-!-padding-bottom-6">
    <div class="govuk-width-container">
      {% if largeUpdateTile or (updatesContent | length) or (keyInfo.data | length) %}
        {% include '../partials/homepage/updates-grid.njk' %}
      {% endif %}

      {{ categoryBlock({
        title: t("pages:home.featured"),
        id: 'featuredContent',
        data: featuredContent
      }, t) }}

      {{ categoryBlock({
        title: t("pages:home.recentlyAdded"),
        viewAllUrl: '/recently-added',
        id: 'recentlyAdded',
        data: recentlyAddedHomepageContent
      }, t) }}

      {{ categoryBlock({
        title: t("pages:home.exploreTheHub"),
        id: 'exploreContent',
        data: exploreContent,
        hideHorizontalRule: true
      }, t) }}
    </div>
  </section>
{% endblock %}
