{% extends "../partials/layout.njk" %}
{% from "../partials/breadcrumb.njk" import breadcrumb, breadcrumbBackForward %}

{% set pageTitle = applicationName + " - Tag" %}
{% set mainClasses = "govuk-body" %}

{% if tag %}
  {% set feedbackContentType = tag.type or '' %}
  {% set feedbackTitle = tag.name or '' %}
  {% if tag.type == "category" %}
    {% set feedbackCategories = tag.name or '' %}
  {% elif tag.type == "series" %}
    {% set feedbackSeries = tag.name or '' %}
  {% elif tag.type == "topic" %}
    {% set feedbackTopics = tag.name or '' %}
  {% endif %}
{% endif %}

{% block content %}
  {% if tag %}
    {{ breadcrumbBackForward() }}
    {% if tag.breadcrumbs and tag.breadcrumbs.length %}
      {{ breadcrumb(tag.breadcrumbs) }}
    {% endif %}

    {% if tag.type == "category" %}
      <h1>{{ tag.name or "Tag" }}</h1>
    {% endif %}

    {% if tag.type == "topic" %}
      {% include "./tagTopic.njk" %}
    {% elif tag.type == "series" %}
      {% include "./tagSeries.njk" %}
    {% elif tag.type == "category" %}
      {% include "./tagCategory.njk" %}
    {% endif %}
  {% else %}
    <h1>Tag not found</h1>
    <p>We could not find this tag.</p>
  {% endif %}
{% endblock %}
