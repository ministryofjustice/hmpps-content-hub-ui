<section class="hmpps-home-section--dark govuk-!-padding-top-6 govuk-!-padding-bottom-6 govuk-!-margin-top-6">
	<div class="govuk-width-container">
		{% if tag.categoryFeaturedContent and tag.categoryFeaturedContent.length %}
			<div class="govuk-grid-row">
				<div class="govuk-grid-column-full">
					<h2 class="govuk-heading-m">Featured</h2>
				</div>

				{% for item in tag.categoryFeaturedContent %}
					<div class="govuk-grid-column-one-quarter">
						{% if item.thumbnailUrl %}
							<img class="hmpps-category__thumbnail" src="{{ item.thumbnailUrl }}" alt="{{ item.title or 'Featured content thumbnail' }}">
						{% endif %}
						<h3 class="govuk-heading-s">
							<a class="govuk-link" href="{{ item.href or '#' }}">{{ item.title or item.linkText or 'Untitled' }}</a>
						</h3>
						{% if item.summary %}
							<p>{{ item.summary }}</p>
						{% endif %}
					</div>
				{% endfor %}
			</div>
		{% endif %}

		<div class="govuk-grid-row govuk-!-margin-top-6">
			<div class="govuk-grid-column-full">
				<h2 class="govuk-heading-m">In this section</h2>
			</div>

			{% if tag.categoryMenu and tag.categoryMenu.length %}
				{% for link in tag.categoryMenu %}
					<div class="govuk-grid-column-one-quarter">
						{% if link.thumbnailUrl %}
							<img class="hmpps-category__thumbnail" src="{{ link.thumbnailUrl }}" alt="{{ link.linkText or 'Section thumbnail' }}">
						{% endif %}
						<a class="govuk-link" href="{{ link.href or '#' }}">{{ link.linkText or link.title or 'Untitled' }}</a>
					</div>
				{% endfor %}
			{% else %}
				<div class="govuk-grid-column-full">
					<p>No links are available for this category yet.</p>
				</div>
			{% endif %}
		</div>
	</div>
</section>
