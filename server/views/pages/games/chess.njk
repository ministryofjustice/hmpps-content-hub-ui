{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% extends "../../partials/layout.njk" %}
{% from "../../partials/breadcrumb.njk" import breadcrumb, breadcrumbNavigation %}

{% block head %}
  <link href="/assets/js/games/chess/chessboard.css" rel="stylesheet" type="text/css"/>
  <!-- chess -->
  <script nonce="{{ cspNonce }}" src="/assets/jquery.min.js"></script>
  <script nonce="{{ cspNonce }}" src="/assets/js/games/chess/chess.min.js"></script>
  <script nonce="{{ cspNonce }}" src="/assets/chessboard-1.0.0.min.js"></script>
  <script nonce="{{ cspNonce }}" src="/assets/stockfish.js"></script>
  {{ super() }}
{% endblock %}

{% set pageTitle = applicationName + " - Chess" %}

{% block content %}
  {{ breadcrumbNavigation(t) }}
  {{ breadcrumb(breadcrumbs) }}

  <div class="govuk-main-wrapper">

    <h1 class="govuk-heading-l">Chess</h1>

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        <div class="game-board-container">
          <span class="govuk-heading-s govuk-!-margin-bottom-2 govuk-hub-computer" id="time1"></span>
          <div class="main-board" id="board"></div>
          <div class="messages" id="messages"></div>
          <span class="govuk-heading-s govuk-!-margin-bottom-2 govuk-hub-human" id="time2"></span>
          <div class="engine-status" id="engineStatus">...</div>
        </div>
        <div class="moves-container">
          <span class="govuk-heading-s govuk-!-margin-bottom-2">Moves:</span>
          <div class="move-lists" id="pgn">Waiting for the first move!</div>
        </div>
        <div class="settings-container">
          <span class="govuk-heading-s govuk-!-margin-bottom-2">Game settings:</span>
          <div class="govuk-form-group">
            <label class="govuk-label" for="playerColor">
          Play with
        </label>
            <select class="govuk-select govuk-hub-full-width" id="playerColor" name="playerColor">
              <option value="white" selected>White</option>
              <option value="black">Black</option>
            </select>
          </div>

          <div class="govuk-form-group">
            <label for="color" class="govuk-label">Pawns get promoted to</label>
            <select class="govuk-select govuk-hub-full-width" id="promote">
              <option value="q" selected>Queen</option>
              <option value="r">Rook</option>
              <option value="b">Bishop</option>
              <option value="n">Knight</option>
            </select>
          </div>

          <input type="hidden" id="timeBase" value="5"/>

          <input type="hidden"  id="timeInc" value="2"/>

          <div class="govuk-form-group">

            {{ govukRadios({
            classes: "govuk-radios--small",
            idPrefix: "skillLevel",
            name: "skillLevel",
            fieldset: {
              legend: {
                text: "Skill level",
                isPageHeading: false,
                classes: "govuk-fieldset__legend--s"
              }
            },
            items: [
              {
                value: "0",
                checked: true,
                text: "Easy"
              },
              {
                value: "8",
                text: "Medium"
              },
              {
                value: "15",
                text: "Hard"
              },
              {
                value: "20",
                text: "Very hard"
              }
            ]
          }) }}
        </div>
        <div class="govuk-form-group">
          <button type="button" class="govuk-button" id="new-game-button">New Game</button>
        </div>

        <a href="{{ chessGuideHref }}" target="_blank" class="govuk-body govuk-link govuk-link--no-visited-state">How to play chess</a>

        </div>
      </div>
    </div>
  </div>

  <script nonce="{{ cspNonce }}" src="/assets/js/games/chess/enginegame.js"></script>
  <script nonce="{{ cspNonce }}" src="/assets/js/games/chess/game.js"></script>
  <script nonce="{{ cspNonce }}">
    $('#new-game-button').on('click', function() {
        newGame();
    });
  </script>

{% endblock %}
