{%- from "govuk/components/tag/macro.njk" import govukTag -%}
{% extends "../../partials/layout.njk" %}
{% from "../../partials/breadcrumb.njk" import breadcrumb, breadcrumbNavigation %}

{% block head %}
  <link href="/assets/js/games/fadingsnake/stylesheets/main.css" rel="stylesheet"/>
  {{ super() }}
{% endblock %}

{% set pageTitle = applicationName + " - Fading Snake" %}

{% block content %}
  {{ breadcrumbNavigation() }}
  {{ breadcrumb(breadcrumbs) }}

  <main class="govuk-main-wrapper">

    <h1 class="govuk-heading-l">Fading Snake</h1>

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half govuk-body">
        <div class="govuk-grid-row govuk-!-padding-left-2">
            <h2 class="fade_text">Fade</h2>
            <h2 class="fade_text contrast">100%</h2>
        </div>
        <div class="container">
            <div class="grid"></div>
        </div>
        <div class="govuk-heading-s gameMsg"></div>
      </div>
      <div class="govuk-grid-column-one-half govuk-body govuk-!-padding-left-6">
          <div class="scores-container">
            <div class="score-container"></div>
            <div class="best-container"></div>
          </div>
          <div id="hard-mode">
              {{ govukTag({
              text: "Hard Mode",
              classes: "govuk-tag--red"
              })}}
          </div>
          <p>Keep moving your snake around the board, eating the white pellets.</p>
          <p>Don’t hit the wall.</p>
          <p>Don’t hit yourself.</p>
          <p>Don’t fade to nothing.</p>
            <h2>How to play:</h2>
          <p>Arrow Keys	= Left, Right, Up, Down</p>
          <p>Space / Arrow key = Start Game</p>
          <p>Space = Restart</p>
          <p>E Key = Easy Mode</p>
          <p>H Key = Hard Mode</p>
      </div>
    </div>
  </main>
{% endblock %}

{% block bodyEnd %}
  <script src="/assets/js/games/fadingsnake/main.js"></script>
{% endblock %}
